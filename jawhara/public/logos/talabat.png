.alert-model .modal-content{box-shadow:0 5px 15px rgb(0 0 0 / 50%);}/*!sc*/
.alert-model .modal-header{background-color:var( --neutral4);color:var(--primary100);border-bottom:1px solid var(--neutral10);}/*!sc*/
.modal-lg{max-width:900px;}/*!sc*/
.modal-xs{width:300px;}/*!sc*/
.cart-model.modal{top:unset;bottom:0;height:calc(100vh - 123px);}/*!sc*/
@media (max-width:1000px){.cart-model.modal{height:calc(100vh - 72px);}}/*!sc*/
@media (max-width:767px){.cart-model.modal{height:calc(100vh - 118px);}}/*!sc*/
.grocery-cart-modal{width:100%;max-width:100%;min-height:100%;margin:0;padding:0;border-radius:0;}/*!sc*/
@media (max-width:1000px){.grocery-cart-modal{margin:0;padding-bottom:20px;padding-top:10px;}}/*!sc*/
@media (max-width:767px){.grocery-cart-modal{margin:0;padding-bottom:20px;}}/*!sc*/
.grocery-cart-modal .modal-content{border-radius:0;border:none;}/*!sc*/
.grocery-cart-modal .modal-content .modal-body{padding:0;border:none;}/*!sc*/
.clear-confirmation-model-alert .modal-content{border-radius:16px;border:none;width:391px !important;}/*!sc*/
.clear-confirmation-model-alert .modal-content .modal-body{padding:0;border:none;}/*!sc*/
.clear-confirmation-model{width:auto!important;height:auto;background:#FFFFFF;border-radius:16px;min-width:360px;}/*!sc*/
.clear-confirmation-model .heading{font-size:20px;font-style:normal;font-weight:600;line-height:28px;-webkit-letter-spacing:0px;-moz-letter-spacing:0px;-ms-letter-spacing:0px;letter-spacing:0px;text-align:left;padding:0 0 16px 0px;}/*!sc*/
.clear-confirmation-model .text-body{font-style:normal;font-weight:normal;font-size:14px;line-height:20px;padding:0 0 24px 0px;}/*!sc*/
.clear-confirmation-model .section{padding:24px;}/*!sc*/
.clear-confirmation-model .section .btn-yes{width:86px;height:36px;background:#FF5A00;border-radius:8px;border:none;padding:8px 12px;}/*!sc*/
.clear-confirmation-model .section .btn-yes span{font-style:normal;font-weight:500;font-size:14px;line-height:20px;text-align:center;color:#FFFFFF;-webkit-flex:none;-ms-flex:none;flex:none;-webkit-letter-spacing:0px;-moz-letter-spacing:0px;-ms-letter-spacing:0px;letter-spacing:0px;}/*!sc*/
.clear-confirmation-model .section .btn-no{width:auto;height:36px;background:#FFFFFF;border:1px solid #FF5A00;box-sizing:border-box;border-radius:8px;margin:0px 16px 0px 16px;padding:8px 12px;}/*!sc*/
.clear-confirmation-model .section .btn-no span{font-style:normal;font-weight:500;font-size:14px;line-height:20px;text-align:center;color:#FF5A00;}/*!sc*/
.alert-marshmallow .modal-content{background:var(--neutral-white);border-radius:16px;border:none;height:auto;min-width:360px;padding:24px;width:auto !important;}/*!sc*/
.alert-marshmallow .modal-content .heading{font-size:20px;font-weight:600;line-height:28px;padding-bottom:16px;}/*!sc*/
.alert-marshmallow .modal-content .text-body{font-size:14px;line-height:20px;padding-bottom:24px;}/*!sc*/
.alert-marshmallow .modal-content .alert-marshmallow-button{min-width:85px;}/*!sc*/
.alert-marshmallow .modal-content .alert-marshmallow-button.btn-cancel{background:#ffffff;border:1px solid #ff5a00;color:#ff5a00;}/*!sc*/
.primary-text{color:var(--primary100);}/*!sc*/
.muted{color:var(--muted);}/*!sc*/
.light-text{color:var(--neutral70) !important;}/*!sc*/
.dark-gray{color:var(--neutral70) !important;}/*!sc*/
.green{color:var(--success100) !important;}/*!sc*/
.green-bg{background-color:var(--success100) !important;}/*!sc*/
.white{color:var(--neutral-white) !important;}/*!sc*/
.color-black{color:var(--neutral100) !important;}/*!sc*/
.error{color:var(--danger100) !important;}/*!sc*/
.color-primary{color:var(--primary100) !important;}/*!sc*/
.color-black{color:var(--body-black) !important;}/*!sc*/
.color-fb{color:#5777b9;}/*!sc*/
.color-twitter{color:#00aced;}/*!sc*/
.bg-primary{background-color:var(--primary100) !important;}/*!sc*/
.bg-header-alert{background-color:var(--neutral4) !important;}/*!sc*/
.bg-light-grey{background-color:var(--neutral4);}/*!sc*/
.bg-white{background-color:var(--neutral-white);}/*!sc*/
.b-a{border:1px solid var(--border-color);}/*!sc*/
.b-b{border-bottom:1px solid var(--border-color) !important;}/*!sc*/
.b-radius{border-radius:5px;}/*!sc*/
.b-radius-3{border-radius:3px;}/*!sc*/
.b-radius-none{border-radius:0;}/*!sc*/
@media (max-width:767px){.b-m-0{border:0!important;}.b-b-m{border-bottom:1px solid var(--border-color);}.text-m-center{text-align:center;}}/*!sc*/
.box-shadow{box-shadow:0 0 5px 0 var(--box-shadow);}/*!sc*/
.b-t{border-top:1px solid var(--border-color);}/*!sc*/
.b-r{border-inline-end:1px solid var(--border-color);}/*!sc*/
.b-l{border-inline-start:1px solid var(--border-color);}/*!sc*/
.b-none{border:none !important;}/*!sc*/
.wrap{white-space:initial !important;}/*!sc*/
.lin-thr{-webkit-text-decoration:line-through;text-decoration:line-through;}/*!sc*/
.ellipsis{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}/*!sc*/
.markdown-rich-text-block h1{margin-bottom:20px;}/*!sc*/
.markdown-rich-text-block ul,.markdown-rich-text-block ol{margin:0 20px;}/*!sc*/
.text-start{text-align:start;}/*!sc*/
.cart-gem-info{border-bottom-right-radius:3px;border-bottom-left-radius:3px;background-color:var(--blue);color:var(--neutral-white);}/*!sc*/
.cart-gem-info .timer-img{-webkit-animation:spin 3.5s ease-in 0.2s infinite reverse;animation:spin 3.5s ease-in 0.2s infinite reverse;}/*!sc*/
.global-spinner{background-color:#00000091;width:100%;height:100%;display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-box-pack:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;position:fixed;top:0;left:0;z-index:9999999;}/*!sc*/
.global-spinner img{z-index:999;}/*!sc*/
.global-spinner::after{width:100px;height:100px;display:block;background:#fff;padding:4px;content:'';position:absolute;border-radius:4px;}/*!sc*/
.closeBtn{background:url('/assets/images/close_desktop.png') no-repeat 0 0;width:30px;height:27px;position:absolute;right:-27px;top:-30px;}/*!sc*/
.gemoffer-expired{max-width:600px;margin:30px auto;}/*!sc*/
.gemoffer-expired .closeBtnMob{background:url('/assets/images/close_white.png') no-repeat 0 0;width:35px;height:35px;position:absolute;right:-14px;top:-16px;}/*!sc*/
.gemoffer-expired .modal-header .gem-header-icn img{width:18px!important;}/*!sc*/
.gemoffer-expired .modal-header img{height:auto;width:auto;margin-top:0;}/*!sc*/
.gemoffer-expired .modal-header .gem-logo{position:absolute;left:50%;top:-18px;-webkit-transform:translateX(-50%);-ms-transform:translateX(-50%);transform:translateX(-50%);}/*!sc*/
.gemoffer-expired .modal-header p{margin:60px 0 24px;font-size:24px;color:var(--body-default);}/*!sc*/
.gemoffer-expired .modal-body{padding:0;background-color:var(--neutral4);border-bottom-right-radius:3px;border-bottom-left-radius:3px;}/*!sc*/
.gemoffer-expired .gem-footer{padding:23px 0;border-bottom-right-radius:3px;border-bottom-left-radius:3px;}/*!sc*/
@media (max-width:767px){.gemoffer-expired{margin:20px;}}/*!sc*/
.bin-offer-modal{max-width:600px;}/*!sc*/
@media (max-width:767px){.bin-offer-modal{margin:0;}}/*!sc*/
.bin-offer-modal .modal-body{padding :0;border:0;}/*!sc*/
.bin-offer-modal .modal-content{background:var(--neutral4);padding:24px;}/*!sc*/
@media (max-width:767px){.bin-offer-modal .modal-content{background:transparent;border:0;box-shadow:none;padding:0 !important;}}/*!sc*/
.bin-offer-modal .swiper-slide{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;max-width:171px;padding:40px 16px;background:#fff;text-align:center;height:195px;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;}/*!sc*/
.bin-offer-modal .swiper-slide img{max-width:40px;margin-bottom:24px;}/*!sc*/
.bin-offer-modal .swiper-slide + .swiper-slide{margin-inline-start:16px;}/*!sc*/
@media (max-width:767px){.bin-offer-modal .swiper-slide{width:40%!important;border-radius:4px;}}/*!sc*/
.swiper-right{background-image:url('/assets/images/slider_arrow_right.png');background-repeat:no-repeat;position:absolute;top:50%;right:0;z-index:999;width:25px;height:50px;cursor:pointer;background-position:0 -3px;}/*!sc*/
.swiper-left{background-image:url('/assets/images/slider_arrow_left.png');position:absolute;top:50%;left:0;z-index:999;width:25px;height:50px;cursor:pointer;background-position:-1px -3px;}/*!sc*/
.modal-header{border-bottom:0;}/*!sc*/
.menupopover{top:5px !important;width:255px;}/*!sc*/
