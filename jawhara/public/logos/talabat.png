.tick{background:url(/assets/images/map-first.png) no-repeat -6px -99px;background-size:33px;width:24px;height:30px;}/*!sc*/
.dropdown-text{width:80%;}/*!sc*/
.mobile-address{margin:0 !important;min-height:100% !important;}/*!sc*/
.mobile-address .modal-dialog{position:fixed;margin:0;width:100%;height:100%;padding:0;}/*!sc*/
.mobile-address .modal-dialog{max-height:60%;bottom:0;-webkit-transform:translateY(100%);-ms-transform:translateY(100%);transform:translateY(100%);}/*!sc*/
.mobile-address .modal-content{position:absolute;top:40%;right:0;bottom:0;left:0;border:none;border-radius:0;}/*!sc*/
.mobile-address .modal-header{position:absolute;top:0;right:0;left:0;padding:16px;border:0;background:#fff;}/*!sc*/
.mobile-address .modal-body{position:absolute;top:60px;bottom:60px;width:100%;overflow:auto;padding:0;}/*!sc*/
.mobile-address .modal-footer{position:absolute;right:0;bottom:0;left:0;padding:10px;background:#fff;text-align:left;}/*!sc*/
.mobile-address .loc-address{width:20px;display:block;height:25px;background-position:-7px -41px;}/*!sc*/
.mobile-address .loc-address{background:url(/assets/images/map-first.png) no-repeat -7px -37px;background-size:34px;}/*!sc*/
.areaSelectionPopup .search-icon{position:absolute;right:7px;bottom:7px;z-index:10;}/*!sc*/
.areaSelectionPopup input{height:40px;}/*!sc*/
.areaSelectionPopup .area-section{height:475px;overflow:auto;}/*!sc*/
